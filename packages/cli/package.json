{
  "name": "@linka/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "linka": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "find src -name '*.test.ts' -print0 | xargs -0 node --import tsx --test",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@linka/config": "workspace:^",
    "@linka/shared": "workspace:^"
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  }
}
