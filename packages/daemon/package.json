{
  "name": "@linka/daemon",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test src/app.test.ts src/container/index.test.ts src/server.test.ts && tsx src/db/run-db-tests.ts",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.3",
    "@linka/config": "workspace:^",
    "@linka/harness": "workspace:^",
    "@linka/shared": "workspace:^",
    "better-sqlite3": "^12.10.0",
    "hono": "^4.12.19"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "tsx": "^4.19.2"
  }
}
